# Mock toggle — when true, the app runs entirely against typed mocks.
# Set to false only when real ETG sandbox credentials are configured.
ETG_USE_MOCKS=true

# ETG sandbox host. Production is api.worldota.net.
ETG_BASE_URL=https://api-sandbox.worldota.net

# Credentials. Leave blank if ETG_USE_MOCKS=true.
ETG_KEY_ID=
ETG_KEY=

# Default search residency (ISO 3166-1 alpha-2). Required by ETG.
ETG_DEFAULT_RESIDENCY=gb

# Database
# Local dev (Docker Postgres):
#   docker run -d --name pg-mvp -e POSTGRES_PASSWORD=dev -p 5432:5432 postgres:16
DATABASE_URL="postgresql://postgres:dev@localhost:5432/postgres"

# Production (Supabase):
# Set both in Vercel environment variables.
# DATABASE_URL — pooled connection via Supavisor (port 6543, used by the app at runtime)
# DIRECT_URL   — direct connection (port 5432, used by prisma migrate deploy)
# Both are available in Supabase dashboard → Project Settings → Database → Connection string.
DIRECT_URL=

# Production (Neon — alternative):
# DATABASE_URL_UNPOOLED=
