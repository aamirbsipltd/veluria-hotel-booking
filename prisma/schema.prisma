// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Booking {
  id                String    @id @default(cuid())
  partnerOrderId    String    @unique
  etgOrderId        String?
  itemId            String?
  status            String
  hid               Int
  hotelName         String
  checkin           DateTime
  checkout          DateTime
  guestsJson        String
  bookHash          String
  totalAmount       String
  currencyCode      String
  paymentType       String
  leadGuestFirst    String
  leadGuestLast     String
  leadGuestEmail    String
  leadGuestPhone    String?
  cancellationJson  String
  freeCancelBefore  DateTime?
  rawFormResponse   String?
  rawFinishResponse String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}
